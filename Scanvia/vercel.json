{
  "buildCommand": "npm install",
  "devCommand": "node server.js",
  "installCommand": "npm install",
  "env": {},
  "functions": {
    "api/[...path].js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/[...path]"
    },
    {
      "source": "/static/(.*)",
      "destination": "/public/static/$1"
    },
    {
      "source": "/(.*\\.html)",
      "destination": "/public/$1"
    },
    {
      "source": "/(.*\\.js)",
      "destination": "/public/$1"
    },
    {
      "source": "/(.*\\.css)",
      "destination": "/public/$1"
    },
    {
      "source": "^/(?!api)(.*)$",
      "destination": "/api/[...path]"
    }
  ]
}
